# receiving_app configuration
# Copy this file to .env and fill in all values before running.
# No value should be left blank in production.

# Absolute path to the SQLite database file
DB_PATH=

# Absolute path to the base directory where rotating log files are written
LOG_DIR=

# Absolute path to the directory where purchase order source downloads are saved
DOWNLOAD_DIR=

# Sync loop polling interval in seconds (integer; default: 10)
POLL_INTERVAL_SECS=

# Base URL of the order management portal (no trailing slash)
SOURCE_BASE_URL=

# Login credentials for the purchase order source system
SOURCE_USERNAME=
SOURCE_PASSWORD=

# Base URL of the result sink API (no trailing slash)
SINK_BASE_URL=

# API token for the result sink service
SINK_API_TOKEN=

# Board identifier in the result sink for posting receiving outcomes
SINK_BOARD_ID=

# Group identifier in the result sink for successfully received items
SINK_RECEIVED_GROUP_ID=

# Group identifier in the result sink for items with no matching product
SINK_NO_MATCH_GROUP_ID=

# Group identifier in the result sink for items requiring manual attention
SINK_ATTENTION_GROUP_ID=

# Scanner input method: "wedge" (USB HID keyboard wedge) or "manual" (text entry)
# Default: wedge
SCANNER_TYPE=

# Printer output method: "preview" (HTML label opened in browser)
# Default: preview
PRINTER_TYPE=

# Purchase order source adapter: "portal" (live scraper) or "fake" (JSON fixture)
# Default: portal
SOURCE_TYPE=

# Result sink adapter: "graphql" (live board API) or "null" (log only, no network)
# Default: graphql
SINK_TYPE=

# Path to the JSON fixture file used when SOURCE_TYPE=fake
# Default: test_data/pos.json
FAKE_SOURCE_DATA=
